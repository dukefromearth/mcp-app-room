{
  "name": "mcp-app-room",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*"
  ],
  "scripts": {
    "help": "node ./scripts/commands-help.mjs",
    "dev": "concurrently \"npm run roomd:start\" \"npm run host:start\"",
    "check:dev": "npm run verify:fast",
    "host:start": "node ./scripts/run-host.mjs start",
    "host:dev": "node ./scripts/run-host.mjs dev",
    "host:open": "node ./scripts/open-room.mjs",
    "roomd:start": "node ./scripts/run-roomd.mjs start",
    "roomd:cli": "go run ./tools/roomctl/cmd/roomctl",
    "fixture:integration-server": "node ./e2e/fixtures/integration-server/main.mjs",
    "fixture:integration-server:stdio": "node ./e2e/fixtures/integration-server/main.mjs --stdio",
    "repo:guard": "node tools/repo-guard/check.mjs",
    "repo:guard:strict": "node tools/repo-guard/check.mjs --strict",
    "repo:guard:baseline": "node tools/repo-guard/check.mjs --write-baseline",
    "repo:doctor": "node tools/repo-guard/doctor.mjs",
    "setup:hooks": "bash scripts/install-git-hooks.sh",
    "build": "npm run --workspace services/roomd build && npm run --workspace apps/host-web build",
    "test:roomd": "npm run --workspace services/roomd test",
    "test:host": "npm run --workspace apps/host-web test",
    "test": "npm run test:roomd && npm run test:host",
    "test:go": "go test ./...",
    "test:all": "npm run test && npm run test:go",
    "verify:fast": "npm run repo:guard && npm run check:real-mcp-entrypoints && npm run arch:lint && npm run docs:check && npm run dev-sidebar:check-contracts",
    "verify": "npm run verify:fast && npm run build && npm run test:all",
    "test:integration:real-mcp": "playwright test e2e/playwright/roomctl-await-real-server.e2e.spec.ts",
    "check:real-mcp-entrypoints": "node tools/repo-guard/check-real-mcp-entrypoints.mjs",
    "verify:full": "npm run verify && npm run playwright:test && npm run conformance:tier1",
    "conformance:run": "npm run --workspace services/roomd conformance:run --",
    "conformance:check": "npm run --workspace services/roomd conformance:check --",
    "conformance:tier1": "npm run conformance:run && npm run conformance:check -- --threshold 1.0",
    "docs:check": "node tools/docs/check-roomd-governance-docs.mjs",
    "dev-sidebar:check-contracts": "node tools/dev-sidebar/check-contract-drift.mjs",
    "arch:lint": "depcruise --config .dependency-cruiser.cjs --ignore-known .dependency-cruiser-known-violations.json apps services",
    "arch": "node tools/arch/arch.mjs",
    "playwright": "node scripts/playwright-cdp-shell.mjs",
    "playwright:test": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "1.57.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dependency-cruiser": "^17.3.8",
    "fast-glob": "^3.3.3",
    "playwright": "1.57.0",
    "ts-morph": "^27.0.2",
    "typescript": "^5.9.3",
    "yaml": "^2.8.2"
  }
}
