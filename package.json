{
  "name": "mcp-app-room",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*"
  ],
  "scripts": {
    "start": "concurrently \"npm run roomd:start\" \"npm run host:start\"",
    "host:start": "cross-env DANGEROUSLY_ALLOW_SANDBOX=true ROOMD_URL=http://localhost:8090 HOST_MODE=room npm run --workspace apps/host-web start",
    "host:dev": "cross-env DANGEROUSLY_ALLOW_SANDBOX=true ROOMD_URL=http://localhost:8090 HOST_MODE=room npm run --workspace apps/host-web dev",
    "roomd:start": "npm run --workspace services/roomd start",
    "roomd:cli": "go run ./tools/roomctl/cmd/roomctl",
    "repo:guard": "node tools/repo-guard/check.mjs",
    "repo:guard:strict": "node tools/repo-guard/check.mjs --strict",
    "repo:guard:baseline": "node tools/repo-guard/check.mjs --write-baseline",
    "repo:doctor": "node tools/repo-guard/doctor.mjs",
    "setup:hooks": "bash scripts/install-git-hooks.sh",
    "build": "npm run --workspace services/roomd build && npm run --workspace apps/host-web build",
    "test": "npm run --workspace services/roomd test",
    "test:go": "go test ./...",
    "test:all": "npm run test && npm run test:go",
    "check:dev": "npm run repo:guard && npm run arch:lint",
    "arch:lint": "depcruise --config .dependency-cruiser.cjs --ignore-known .dependency-cruiser-known-violations.json apps services",
    "arch:lint:strict": "depcruise --config .dependency-cruiser.cjs apps services",
    "arch:baseline": "depcruise-baseline --config .dependency-cruiser.cjs apps services",
    "arch:gen": "bash scripts/generate-arch.sh docs/generated",
    "arch:check": "bash scripts/check-arch.sh",
    "arch:render": "ARCH_RENDER=1 bash scripts/generate-arch.sh docs/generated",
    "arch:deps:mermaid": "bash scripts/generate-arch.sh docs/generated --deps-only",
    "test:e2e": "playwright test",
    "playwright": "node scripts/playwright-cdp-shell.mjs",
    "playwright:test": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "1.57.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dependency-cruiser": "^17.3.8",
    "fast-glob": "^3.3.3",
    "playwright": "1.57.0",
    "ts-morph": "^27.0.2",
    "typescript": "^5.9.3"
  }
}
