{
  "name": "mcp-app-room",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*"
  ],
  "scripts": {
    "start": "concurrently \"npm run roomd:start\" \"npm run host:start\"",
    "host:start": "npm run --workspace apps/host-web start",
    "host:dev": "npm run --workspace apps/host-web dev",
    "roomd:start": "node ./scripts/run-roomd.mjs start",
    "roomd:start:strict": "node ./scripts/run-roomd.mjs start --profile strict",
    "roomd:dev": "node ./scripts/run-roomd.mjs dev",
    "roomd:dev:strict": "node ./scripts/run-roomd.mjs dev --profile strict",
    "roomd:cli": "go run ./tools/roomctl/cmd/roomctl",
    "repo:guard": "node tools/repo-guard/check.mjs",
    "repo:guard:strict": "node tools/repo-guard/check.mjs --strict",
    "repo:guard:baseline": "node tools/repo-guard/check.mjs --write-baseline",
    "repo:doctor": "node tools/repo-guard/doctor.mjs",
    "setup:hooks": "bash scripts/install-git-hooks.sh",
    "build": "npm run --workspace services/roomd build && npm run --workspace apps/host-web build",
    "test": "npm run --workspace services/roomd test",
    "test:go": "go test ./...",
    "test:all": "npm run test && npm run test:go",
    "conformance:run": "npm run --workspace services/roomd conformance:run --",
    "conformance:check": "npm run --workspace services/roomd conformance:check --",
    "conformance:tier1": "npm run conformance:run && npm run conformance:check -- --threshold 1.0",
    "conformance:tier2": "npm run conformance:run && npm run conformance:check -- --threshold 0.8",
    "docs:check": "node tools/docs/check-roomd-governance-docs.mjs",
    "check:dev": "npm run repo:guard && npm run arch:lint && npm run dev-sidebar:check-contracts",
    "dev-sidebar:check-contracts": "node tools/dev-sidebar/check-contract-drift.mjs",
    "arch:lint": "depcruise --config .dependency-cruiser.cjs --ignore-known .dependency-cruiser-known-violations.json apps services",
    "arch:lint:strict": "depcruise --config .dependency-cruiser.cjs apps services",
    "arch:baseline": "depcruise-baseline --config .dependency-cruiser.cjs apps services",
    "arch": "node tools/arch/arch.mjs",
    "test:e2e": "playwright test",
    "playwright": "node scripts/playwright-cdp-shell.mjs",
    "playwright:test": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "1.57.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dependency-cruiser": "^17.3.8",
    "fast-glob": "^3.3.3",
    "playwright": "1.57.0",
    "ts-morph": "^27.0.2",
    "typescript": "^5.9.3",
    "yaml": "^2.8.2"
  }
}
